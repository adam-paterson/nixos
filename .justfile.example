# Local Justfile - Machine-Specific Overrides
# Copy this to .justfile.local and customize for your machine
# .justfile.local is gitignored

# Import the main Justfile
import? '../Justfile'

# Override default hostname if needed
# _hostname := "my-macbook"

# Add custom recipes for this specific machine
# Example:
# my-custom-task:
#     echo "Running custom task for {{_hostname}}"
#     # Your custom commands here

# Example: Quick backup before switching
# backup-then-switch:
#     echo "📦 Creating backup..."
#     rsync -av ~/.config ~/backups/config-$(date +%Y%m%d)
#     just switch

# Example: Custom development setup
# dev-setup:
#     echo "🔧 Setting up development environment..."
#     just build
#     # Additional setup commands

# Example: Machine-specific package search
# find package:
#     just search {{package}}
#     nix-env -qa {{package}}
